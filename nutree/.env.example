# ─────────────────────────────────────────────
# NUTREE CLINIC — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in values
# Never commit .env.local to git
# ─────────────────────────────────────────────

# Anthropic — AI chat widget
ANTHROPIC_API_KEY=

# Google Cloud — PHI storage (sign BAA first)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# SendGrid — transactional email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=care@nutreeclinic.com
SENDGRID_ATARA_EMAIL=

# Square — payments
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
NEXT_PUBLIC_SQUARE_APP_ID=

# LifeFile — pharmacy API
LIFEFILE_API_KEY=
LIFEFILE_BASE_URL=

# Site
NEXT_PUBLIC_SITE_URL=https://nutreeclinic.com
